---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTransition from '../components/motion/PageTransition';
import TechLogoGrid from '../components/projects/TechLogoGrid';
import stackData from '../content/data/stack.json';
import socialData from '../content/data/social.json';

export const prerender = true;
---

<BaseLayout title="About" description="Learn more about who I am, what I do, and how I got here.">
  <PageTransition client:load>
    <div class="w-full max-w-170 mx-auto px-6 pt-16 pb-16">

      <!-- Header -->
      <section class="mb-12">
        <h1 class="font-display font-bold text-[clamp(26px,6vw,40px)] text-fg m-0 mb-2">About Me</h1>
        <p class="font-sans text-base text-muted m-0">Developer, builder, occasional writer.</p>
      </section>

      <!-- Bio -->
      <section class="mb-14">
        <div class="flex flex-col gap-5 items-start">
          <div class="neo-card w-[100px] h-[100px] flex items-center justify-center bg-accent font-display font-bold text-[32px] text-[#1f1f1f] shrink-0">
            YN
          </div>
          <div>
            <p class="font-sans text-base text-muted leading-[1.75] m-0 mb-4">
              I'm a frontend engineer based in Jakarta, Indonesia. I specialize in building
              modern web applications with React, Next.js, and TypeScript — with a strong focus
              on clean code, great UX, and performance.
            </p>
            <p class="font-sans text-base text-muted leading-[1.75] m-0 mb-4">
              When I'm not coding, I write on this blog about things I've learned, patterns I've
              found useful, and tools worth sharing. I believe in learning in public.
            </p>
            <p class="font-sans text-base text-muted leading-[1.75] m-0">
              Currently open to freelance projects. Let's build something great together.
            </p>
          </div>
        </div>
      </section>

      <!-- Experience -->
      <section class="mb-14">
        <div class="border-b-2 border-ink pb-3 mb-6">
          <h2 class="font-display font-bold text-[22px] text-fg m-0">Experience</h2>
        </div>
        <div class="flex flex-col gap-6">
          {[
            { role: 'Frontend Developer', company: 'Awesome Startup', period: '2024 – Present', desc: 'Building scalable React applications, leading frontend architecture decisions, and improving DX with internal tooling.' },
            { role: 'Full-stack Developer', company: 'Digital Agency', period: '2022 – 2024', desc: 'Delivered 10+ client projects using Next.js, Node.js, and PostgreSQL. Reduced average page load time by 40%.' },
            { role: 'Junior Web Developer', company: 'Tech Company', period: '2021 – 2022', desc: 'Built and maintained web applications for internal tools and client-facing dashboards.' },
          ].map((item) => (
            <div class="border-l-[3px] border-accent pl-4">
              <div class="flex flex-wrap gap-2 items-baseline mb-1">
                <span class="font-display font-bold text-base text-fg">{item.role}</span>
                <span class="font-sans text-[13px] text-muted">at {item.company}</span>
              </div>
              <p class="font-sans text-xs font-medium text-subtle m-0 mb-2">{item.period}</p>
              <p class="font-sans text-sm text-muted m-0 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Tech Stack -->
      <!-- <section class="mb-14">
        <div class="border-b-2 border-ink pb-3 mb-6">
          <h2 class="font-display font-bold text-[22px] text-fg m-0">Tools & Technologies</h2>
        </div>
        <TechLogoGrid stack={stackData} client:load />
      </section> -->

      <!-- Social Links -->
      <section>
        <div class="border-b-2 border-ink pb-3 mb-6">
          <h2 class="font-display font-bold text-[22px] text-fg m-0">Find Me Online</h2>
        </div>
        <div class="flex flex-wrap gap-3">
          {socialData.links.map((link) => (
            <a
              href={link.url}
              target={link.url.startsWith('mailto') ? undefined : '_blank'}
              rel="noopener noreferrer"
              class="neo-btn font-display font-semibold text-sm text-fg bg-surface px-4 py-2 no-underline"
            >
              {link.label} ↗
            </a>
          ))}
          <a
            href="/resume.pdf"
            download
            class="neo-btn font-display font-semibold text-sm text-[#1f1f1f] bg-accent px-4 py-2 no-underline"
          >
            Download Resume ↓
          </a>
        </div>
      </section>

    </div>
  </PageTransition>
</BaseLayout>
