---
import socialData from '../../content/data/social.json';
---

<footer class="border-t-2 border-ink mt-16 py-8 bg-surface transition-colors duration-200">
  <div class="w-full max-w-170 mx-auto px-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">

    <p class="font-sans text-[13px] text-muted m-0">
      &copy; {new Date().getFullYear()} Ainur Rahman. All rights reserved.
    </p>

    <div class="flex flex-wrap gap-5">
      {socialData.links.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="font-sans text-[13px] font-medium text-fg no-underline border-b border-transparent hover:border-accent transition-colors duration-150"
        >
          {link.label}
        </a>
      ))}
      <!-- <a
        href="/rss.xml"
        class="font-sans text-[13px] font-medium text-fg no-underline border-b border-transparent hover:border-accent transition-colors duration-150"
      >
        RSS
      </a> -->
    </div>

  </div>
</footer>
